# Server frontend: build Vite app, serve with nginx (proxy /api to server_backend)
FROM node:20-alpine AS builder

WORKDIR /app

COPY server/frontend/package.json server/frontend/package-lock.json* ./
RUN npm ci

COPY server/frontend/ .
RUN npm run build

FROM nginx:alpine

COPY server/frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]

# Frontend: build Vite app, serve with nginx (proxy /api to backend)
FROM node:20-alpine AS builder

WORKDIR /app

COPY hospital_client/frontend/package.json hospital_client/frontend/package-lock.json* ./
RUN npm ci

COPY hospital_client/frontend/ .
RUN npm run build

FROM nginx:alpine

COPY hospital_client/frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]

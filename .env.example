# Copy to .env and fill in. Never commit .env.
# Docker: put .env in the same folder as docker-compose.yml; run from that folder.

# PostgreSQL (server stack)
POSTGRES_USER=carp
POSTGRES_PASSWORD=carp
POSTGRES_DB=carp

